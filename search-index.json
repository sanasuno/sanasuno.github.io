index":13,"t":{"18":{"position":[[10,2]]}}}],["実装",{"_index":1,"t":{"9":{"position":[[0,2]]}}}],["師決",{"_index":12,"t":{"18":{"position":[[8,2]]}}}],["日",{"_index":8,"t":{"16":{"position":[[7,1]]}}}],["最強",{"_index":10,"t":{"18":{"position":[[4,2]]}}}],["釣り",{"_index":11,"t":{"18":{"position":[[6,2]]}}}],["願い",{"_index":6,"t":{"16":{"position":[[0,2]]}}}]],"pipeline":["stemmer"]}},{"documents":[{"i":1,"t":"どうも、さなすのです。","s":"はじめに","u":"/blog/2025/02/28/1","p":1},{"i":3,"t":"アーカイブ","s":"","u":"/blog/archive","p":3},{"i":5,"t":"どうも、さなすのです。","s":"ゼンゼロ Ver1.5 感想","u":"/blog/2025/03/11/1","p":5}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/1",[0,0.414,1,0.591,2,0.414]],["t/3",[3,1.349]],["t/5",[0,0.414,1,0.591,2,0.414]]],"invertedIndex":[["",{"_index":1,"t":{"1":{"position":[[3,1],[10,1]]},"5":{"position":[[3,1],[10,1]]}}}],["さなす",{"_index":2,"t":{"1":{"position":[[4,3]]},"5":{"position":[[4,3]]}}}],["どう",{"_index":0,"t":{"1":{"position":[[0,2]]},"5":{"position":[[0,2]]}}}],["アーカイブ",{"_index":3,"t":{"3":{"position":[[0,5]]}}}]],"pipeline":["stemmer"]}},{"documents":[],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[],"invertedIndex":[],"pipeline":["stemmer"]}},{"documents":[{"i":2,"t":"どうも、さなすのです。 というわけで、ブログをこちらに移転しました。 今後はとりあえず旧サイトでやっていたようなゲームの考察なんかがメインになるかと思います。 あと旧サイトの記事も移設予定です。 それでは。","s":"はじめに","u":"/blog/2025/02/28/1","h":"","p":1},{"i":6,"t":"どうも、さなすのです。 ゼンレスゾーンゼロ Ver1.5「輝きのモーメント」の感想です。","s":"ゼンゼロ Ver1.5 感想","u":"/blog/2025/03/11/1","h":"","p":5},{"i":8,"t":"前回（Ver1.4）でメインストーリーとしては一段落し、今回は特別劇場が追加される形に。 これまでの特別劇場とは異なり、主人公のパエトーン兄妹もしっかり話に絡む構成でした。 ジェーンや柳の場合は特別劇場で個人を取り上げ、所属陣営とパエトーンとの絡みはメインストーリーに配置していたのに対し、今回は陣営そのものを特別劇場に配置する都合上、パエトーンと面識のないまま進行するわけにはいかない、というところだったのかな、と。 ただ、ストーリーの流れとしては、正直なところ端折り過ぎたな、という感想です。 特にイヴリン視点なのに、複雑なイヴリンの立場を説明なしにいきなり進行するのでやや混乱しました。 これなら素直にメインストーリーとして十分な尺を使って進めてほしかったですね。あとでスターズ・オブ・リラのメインストーリーは別でやるのかもしれないけど。 それを抜きにして見ると、ストーリーとしては簡潔に纏まっていつつも、後の展開への布石となるような部分も見えてきて（TOPSが次の敵になるのかな？）、メインストーリー第2部への繋ぎとしての役割は十分果たせていたかな、と。","s":"ストーリー","u":"/blog/2025/03/11/1","h":"#ストーリー","p":5},{"i":10,"t":"今回は前半でアストラ、後半でイヴリンが追加。二人ともS級です。","s":"実装エージェント","u":"/blog/2025/03/11/1","h":"#実装エージェント","p":5},{"i":12,"t":"遂にやって来た初の限定支援エージェント。攻撃力、与ダメージ、会心ダメージへのバフに、おまけでHP回復まで引っ提げてきました。 シーザーが防護ながらかなり高いバフ能力を引っ提げて来たので、支援のアストラはどうなるかと思っていたら、しっかりと期待を超えてきてくれましたね。 地味に三人目のエーテル属性ということもあって、朱鳶はかなり強化されたと思います。これまで混沌のヘヴィメタルの効果の起動が結構厳しかったのでね…… あとクイック支援連発によってアンドーが超強化されてたのは笑いました、だって絵面が面白すぎるでしょアンドーミサイル。 もちろん他のアタッカーたちも相当強化されましたし、HP回復も塔で滅茶苦茶助かる。かなり強いですね。","s":"アストラ","u":"/blog/2025/03/11/1","h":"#アストラ","p":5},{"i":14,"t":"後半は炎強攻のイヴリン。連携スキルで火力を出す、という点は今までになかったタイプですね。 ライトが撃破としてかなり噛み合うのもあって、アタッカーとしては火力は高いと思います。流石に雅には及ばないけど ただ個人的な使用感としては、ちょっと回避に癖があるというか、防御面での撃たれ弱さが気になったかな。多分慣れたら問題ないんでしょうけども。 同じ炎強攻の11号の方は目押し要素があるので、好みの問題で使い分けって感じですかね。","s":"イヴリン","u":"/blog/2025/03/11/1","h":"#イヴリン","p":5},{"i":17,"t":"ストーリーはイアスにフォーカスしていてかなり良かったです。特別劇場の後日談としても、旧正月と合わせた季節イベントとしても面白かった。 ただミニゲームの方なんですが、ちょっとステージ数が多くて作業感が強かったかな……。内容自体は嫌いではないんですけどね。 フ○ール○イズの方は素直に楽しかったです。なんせ元が良いからね。","s":"願いがきらめく日","u":"/blog/2025/03/11/1","h":"#願いがきらめく日","p":5},{"i":19,"t":"やっぱ釣りってク○だわ。 ううん……報酬コンプは諦めました、あまりにも苦痛すぎる。 なんかどのゲームでも取り敢えずミニゲームといえば釣り！ってなってるのはなんですかね？ 個人的にはあまり面白いとは思えませんでした。好きな人もいるんだろうけども。 あ、ストーリー自体はよかったです、サブイベントも充実していたし。 ざっとこんな感じですかね。それではVer1.6を楽しんできます。","s":"エルピス最強釣り師決定戦","u":"/blog/2025/03/11/1","h":"#エルピス最強釣り師決定戦","p":5}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/2",[0,1.189,1,0.114,2,1.612,3,2.255,4,2.255,5,2.255,6,0.872,7,0.521,8,2.255,9,2.255,10,2.255,11,1.612,12,2.869,13,2.869,14,2.255,15,0.41,16,0.62,17,1.612,18,0.62,19,1.612,20,2.255,21,2.255,22,2.255,23,1.189,24,0.62,25,1.189,26,0.872,27,1.189,28,2.255,29,2.255,30,2.255]],["t/6",[0,1.415,1,0.117,2,1.92,31,2.685,32,1.415,33,1.039,34,2.685,35,2.685,36,2.685,37,1.92]],["t/8",[1,0.116,6,0.429,7,0.525,15,0.543,16,0.476,17,0.794,18,0.844,23,0.913,24,0.476,27,0.585,32,0.585,33,0.429,37,0.794,38,1.11,39,1.11,40,2.61,41,1.376,42,1.11,43,1.11,44,1.239,45,1.721,46,1.721,47,0.794,48,0.794,49,1.11,50,1.11,5